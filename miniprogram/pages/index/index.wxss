/* 首页 */
.swiper-wrap {
  width: 100%;
  height: 360rpx;
}
.banner-swiper {
  width: 100%;
  height: 100%;
}
.banner-slide {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.banner-title {
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: #fff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}
.banner-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.category-section {
  padding: 24rpx;
}
.category-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 32rpx 36rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
}
.category-text {
  font-size: 30rpx;
  font-weight: var(--font-weight-medium);
  color: var(--text-primary);
}
.category-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
}
.category-emoji {
  font-size: 48rpx;
}

.footer-padding {
  height: 100rpx;
}
