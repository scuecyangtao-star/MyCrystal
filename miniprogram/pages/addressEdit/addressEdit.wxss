.addr-edit-page {
  min-height: 100vh;
  background: var(--page-bg);
  padding: 24rpx;
}

.form {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  margin-bottom: 32rpx;
}
.row {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid var(--border-light);
  position: relative;
}
.row:last-child { border-bottom: none; }
.label {
  width: 150rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
}
.input, .textarea {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 0;
}
.input::placeholder, .textarea::placeholder {
  color: var(--text-placeholder);
}
.textarea {
  min-height: 100rpx;
  padding: 0;
}

.btn-save {
  background: var(--primary);
  color: #fff;
  font-size: 30rpx;
  font-weight: var(--font-weight-medium);
  border: none;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  width: 100%;
}
.btn-del-wrap {
  margin-top: 32rpx;
  text-align: center;
}
.btn-del {
  background: transparent;
  color: var(--text-tertiary);
  font-size: 26rpx;
  border: none;
  padding: 20rpx;
  line-height: 1.4;
}
.btn-del::after {
  border: none;
}
