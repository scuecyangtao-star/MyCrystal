.addr-edit-page {
  min-height: 100vh;
  background: var(--page-bg);
  padding: var(--space-page) 40rpx 120rpx;
}

.form {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  margin-bottom: 32rpx;
}
.row {
  display: flex;
  align-items: center;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid var(--border);
  position: relative;
}
.row:last-child { border-bottom: none; }
.label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: var(--font-weight-regular);
}
.input, .textarea {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}
.textarea {
  min-height: 120rpx;
  padding: 0;
}
.arrow {
  color: var(--text-placeholder);
  font-size: 32rpx;
  margin-left: 16rpx;
}

.btn-save {
  background: var(--primary);
  color: #fff;
  font-size: 30rpx;
  font-weight: var(--font-weight-regular);
  border: none;
  border-radius: var(--radius-lg);
  padding: 28rpx;
}
.btn-del-wrap {
  margin-top: 32rpx;
  text-align: center;
}
.btn-del {
  background: transparent;
  color: var(--text-tertiary);
  font-size: 26rpx;
  border: none;
  padding: 20rpx;
}
