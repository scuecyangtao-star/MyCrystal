<view class="addr-edit-page">
  <view class="form">
    <view class="row">
      <text class="label">收货人</text>
      <input class="input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" maxlength="20" />
    </view>
    <view class="row">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>
    <view class="row">
      <text class="label">所在地区</text>
      <input class="input" placeholder="省/市/区，如：广东省深圳市南山区" value="{{region}}" bindinput="onRegionInput" maxlength="50" />
    </view>
    <view class="row">
      <text class="label">详细地址</text>
      <textarea class="textarea" placeholder="街道、门牌号等" value="{{detail}}" bindinput="onDetailInput" maxlength="100" />
    </view>
  </view>

  <button class="btn-save" bindtap="save">{{isEdit ? '保存修改' : '保存地址'}}</button>

  <view class="btn-del-wrap" wx:if="{{isEdit}}">
    <button class="btn-del" bindtap="delete">删除地址</button>
  </view>
</view>
