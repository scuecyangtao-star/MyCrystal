<view class="confirm-page">
  <!-- 订单商品 -->
  <view class="card">
    <view class="card-title">订单商品</view>
    <view class="preview-row">
      <view wx:for="{{previewItems}}" wx:key="id" class="preview-bead" style="background:{{item.color}}">{{item.name}}</view>
    </view>
    <view class="order-info-row">
      <text class="order-info-label">产品类型</text>
      <text>{{productName}}</text>
    </view>
    <view class="order-info-row">
      <text class="order-info-label">金额</text>
      <text class="order-info-price">¥{{totalPrice}}</text>
    </view>
  </view>

  <!-- 收货地址 -->
  <view class="card">
    <view class="card-title">收货地址</view>
    <view wx:if="{{addresses.length > 0}}">
      <view wx:for="{{addresses}}" wx:key="id"
        class="addr-item {{selectedAddrId === item.id ? 'addr-selected' : ''}}"
        bindtap="selectAddress" data-id="{{item.id}}">
        <view class="addr-radio">
          <view class="radio-dot {{selectedAddrId === item.id ? 'radio-checked' : ''}}"></view>
        </view>
        <view class="addr-content">
          <view class="addr-line1">{{item.name}}  {{item.phone}}</view>
          <view class="addr-line2">{{item.region}} {{item.detail}}</view>
        </view>
      </view>
    </view>
    <view class="addr-empty" wx:else>
      <text>暂无收货地址</text>
    </view>
    <view class="addr-add" bindtap="addAddress">
      <text class="addr-add-icon">+</text>
      <text>添加新地址</text>
    </view>
  </view>

  <!-- 底部提交 -->
  <view class="confirm-bar">
    <view class="confirm-total">
      <text class="confirm-label">合计：</text>
      <text class="confirm-price">¥{{totalPrice}}</text>
    </view>
    <button class="confirm-btn" bindtap="submit">确认下单</button>
  </view>
</view>
